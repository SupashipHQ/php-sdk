{
  "name": "supaship/php-sdk",
  "description": "PHP SDK for Supaship feature flags",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=7.4",
    "ext-json": "*",
    "ext-openssl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6.11"
  },
  "autoload": {
    "psr-4": {
      "Supaship\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Supaship\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "platform": {
      "php": "7.4.33"
    }
  }
}
